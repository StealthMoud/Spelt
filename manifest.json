{
  "manifest_version": 3,
  "name": "Spelt",
  "version": "1.0.0",
  "description": "Organized spelling and vocabulary trainer featuring Spaced Repetition (SRS) scheduling and dashboard sync.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "MacCtrl+Shift+S"
      },
      "description": "Open Spelt Popup"
    }
  }
}
