{
  "manifest_version": 3,
  "name": "Spelt",
  "version": "1.0.0",
  "description": "Organized spelling and vocabulary trainer featuring Spaced Repetition (SRS) scheduling.",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "contextMenus",
    "notifications",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "http://localhost:8081/*",
    "https://tatoeba.org/*",
    "https://translate.googleapis.com/*",
    "https://api.dictionaryapi.dev/*",
    "https://dictionary.cambridge.org/*",
    "https://www.oxfordlearnersdictionaries.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open Spelt Popup"
    },
    "add-selection-to-spelt": {
      "suggested_key": {
        "default": "Alt+Shift+A",
        "mac": "Alt+Shift+A"
      },
      "description": "Add selected text to Spelt Vault"
    }
  }
}
